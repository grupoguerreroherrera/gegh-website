<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>GEGH — IA que transforma empresas</title>
<meta name="description" content="Boutique de Inteligencia Artificial. Implementamos IA que genera ROI real en menos de 7 días. Bucaramanga, Colombia.">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700;1,900&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,600&family=Josefin+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

<style>
/* =====================================================
   VARIABLES — COLORES ORIGINALES EXACTOS
   Negro profundo + Dorado lujo
   ===================================================== */
:root {
  --black:      #080810;
  --black2:     #0d0d18;
  --black3:     #111120;
  --gold:       #c9a84c;
  --gold2:      #e8c96a;
  --gold-dim:   rgba(201,168,76,0.12);
  --gold-glow:  rgba(201,168,76,0.22);
  --gold-border:rgba(201,168,76,0.25);
  --white:      #f5f0e8;
  --white2:     #b8b0a0;
  --white3:     #5a5448;
  --green-wa:   #25D366;

  --serif:      'Playfair Display', Georgia, serif;
  --serif2:     'Cormorant Garamond', Georgia, serif;
  --sans:       'Josefin Sans', sans-serif;

  --r: 8px;
  --ease: cubic-bezier(.4,0,.2,1);
}

/* =====================================================
   RESET
   ===================================================== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--black);
  color: var(--white);
  font-family: var(--serif2);
  line-height: 1.65;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}
a { text-decoration: none; color: inherit; }
button { cursor: pointer; border: none; background: none; font-family: inherit; }
img { display: block; max-width: 100%; }

/* =====================================================
   SCROLL PROGRESS
   ===================================================== */
#prog {
  position: fixed; top: 0; left: 0; width: 0%; height: 2px;
  background: linear-gradient(90deg, var(--gold), var(--gold2));
  z-index: 9999; transition: width .08s linear;
}

/* =====================================================
   SSL BADGE
   ===================================================== */
.ssl-badge {
  display: inline-flex; align-items: center; gap: 5px;
  border: 1px solid rgba(37,211,102,.3);
  background: rgba(37,211,102,.08);
  color: #4ade80;
  font-family: var(--sans); font-size: .62rem; font-weight: 600;
  padding: 3px 10px; border-radius: 20px;
  letter-spacing: .06em; text-transform: uppercase;
}
.ssl-badge::before { content: '🔒'; font-size: .6rem; }

/* =====================================================
   NAVIGATION
   ===================================================== */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  height: 70px;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 32px;
  background: rgba(8,8,16,.90);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--gold-border);
}

.nav-logo-box {
  display: flex; align-items: center; gap: 14px;
}
.nav-logo-letter {
  width: 42px; height: 42px;
  border: 1px solid var(--gold-border);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--serif); font-size: 1.2rem; font-weight: 900;
  color: var(--gold);
}
.nav-logo-text {
  font-family: var(--sans); font-size: .72rem; font-weight: 600;
  letter-spacing: .15em; text-transform: uppercase;
  color: var(--white2); line-height: 1.4;
}
.nav-logo-text strong { color: var(--white); display: block; }

.nav-links {
  display: flex; gap: 28px; list-style: none;
}
.nav-links a {
  font-family: var(--sans); font-size: .72rem; font-weight: 600;
  letter-spacing: .1em; text-transform: uppercase; color: var(--white2);
  transition: color .25s;
}
.nav-links a:hover { color: var(--gold); }

.nav-right { display: flex; align-items: center; gap: 12px; }

/* Gold CTA button — exact original style */
.btn-gold {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--gold);
  color: var(--black);
  font-family: var(--sans); font-size: .72rem; font-weight: 700;
  letter-spacing: .12em; text-transform: uppercase;
  padding: 13px 22px;
  border: none;
  transition: all .25s var(--ease);
  cursor: pointer;
}
.btn-gold:hover {
  background: var(--gold2);
  box-shadow: 0 0 28px var(--gold-glow);
  transform: translateY(-1px);
}
.btn-gold:active { transform: translateY(0); }

/* Ghost button — exact original style */
.btn-ghost {
  display: inline-flex; align-items: center; gap: 8px;
  background: transparent;
  color: var(--gold);
  font-family: var(--sans); font-size: .72rem; font-weight: 600;
  letter-spacing: .12em; text-transform: uppercase;
  padding: 12px 22px;
  border: 1px solid var(--gold-border);
  transition: all .25s var(--ease);
}
.btn-ghost:hover {
  background: var(--gold-dim);
  border-color: var(--gold);
}

/* Hamburger */
.ham {
  display: none; flex-direction: column; gap: 5px; padding: 4px;
}
.ham span {
  display: block; width: 22px; height: 1.5px;
  background: var(--white); border-radius: 1px;
  transition: all .3s var(--ease);
}

/* Mobile overlay */
.mob {
  display: none; position: fixed; inset: 0;
  background: var(--black);
  z-index: 199;
  flex-direction: column; align-items: center; justify-content: center;
  gap: 32px; padding-top: 70px;
}
.mob.open { display: flex; }
.mob a {
  font-family: var(--serif); font-size: 2rem; font-weight: 700;
  color: var(--white2); transition: color .2s;
}
.mob a:hover { color: var(--gold); }
.mob .btn-gold { font-size: .8rem; margin-top: 12px; letter-spacing: .14em; }

/* =====================================================
   HERO — fondo negro con objetos 3D CSS
   ===================================================== */
.hero {
  min-height: 100svh;
  display: flex; flex-direction: column; justify-content: flex-end;
  padding: 0 28px 60px;
  position: relative; overflow: hidden;
}

/* Fondo negro con partículas doradas */
.hero-bg {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 120% 80% at 60% 40%, rgba(20,18,10,.6) 0%, var(--black) 70%);
}

/* Estrellas/partículas de fondo */
.stars {
  position: absolute; inset: 0; pointer-events: none;
}
.star {
  position: absolute; border-radius: 50%;
  background: var(--gold);
  animation: twinkle var(--dur, 3s) ease-in-out infinite;
  animation-delay: var(--del, 0s);
}
@keyframes twinkle {
  0%,100% { opacity: .15; transform: scale(1); }
  50%      { opacity: .7;  transform: scale(1.3); }
}

/* Círculo decorativo original */
.hero-circle {
  position: absolute;
  width: clamp(120px, 22vw, 200px);
  height: clamp(120px, 22vw, 200px);
  border: 1px solid var(--gold-border);
  border-radius: 50%;
  right: clamp(16px, 6vw, 80px);
  top: 50%; transform: translateY(-50%);
  display: flex; align-items: center; justify-content: center;
  animation: circle-rotate 20s linear infinite;
}
.hero-circle::before {
  content: '';
  width: clamp(10px, 2vw, 18px);
  height: clamp(10px, 2vw, 18px);
  background: var(--gold);
  border-radius: 50%;
  box-shadow: 0 0 20px var(--gold-glow);
}
@keyframes circle-rotate {
  from { transform: translateY(-50%) rotate(0deg); }
  to   { transform: translateY(-50%) rotate(360deg); }
}

/* Objeto 3D — esfera/toro CSS animada */
.obj3d {
  position: absolute; pointer-events: none;
}
.obj-torus {
  width: clamp(140px, 28vw, 280px);
  height: clamp(140px, 28vw, 280px);
  right: clamp(60px, 12vw, 160px);
  top: 50%; transform: translateY(-50%);
  border-radius: 50%;
  border: clamp(18px, 4vw, 40px) solid transparent;
  border-top-color: rgba(201,168,76,.5);
  border-right-color: rgba(201,168,76,.3);
  border-bottom-color: rgba(0,180,160,.4);
  box-shadow:
    inset 0 0 40px rgba(201,168,76,.15),
    0 0 60px rgba(201,168,76,.08);
  animation: torus-spin 8s linear infinite;
  filter: blur(0.5px);
}
@keyframes torus-spin {
  from { transform: translateY(-50%) rotate3d(1,.5,0,0deg); }
  to   { transform: translateY(-50%) rotate3d(1,.5,0,360deg); }
}

.obj-sphere {
  width: clamp(70px, 14vw, 140px);
  height: clamp(70px, 14vw, 140px);
  left: clamp(10px, 5vw, 60px);
  top: 35%;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%,
    rgba(0,200,180,.5) 0%,
    rgba(0,100,120,.4) 40%,
    rgba(0,40,60,.6) 80%
  );
  box-shadow:
    0 0 30px rgba(0,200,180,.2),
    inset 0 0 20px rgba(255,255,255,.05);
  animation: sphere-float 6s ease-in-out infinite;
}
@keyframes sphere-float {
  0%,100% { transform: translateY(0) rotate(0deg); }
  50%     { transform: translateY(-20px) rotate(10deg); }
}

/* Líneas decorativas */
.hero-lines {
  position: absolute; inset: 0; pointer-events: none;
  opacity: .15;
}
.hero-lines svg { width: 100%; height: 100%; }

/* Contenido hero */
.hero-content {
  position: relative; z-index: 2;
  max-width: 680px;
}
.hero-title {
  font-family: var(--serif);
  font-size: clamp(3.2rem, 11vw, 7rem);
  font-weight: 900; line-height: 1.0;
  letter-spacing: -.01em;
  margin-bottom: 10px;
}
.hero-title .gold-italic {
  font-style: italic;
  color: var(--gold);
  display: block;
}
.hero-subtitle-en {
  font-family: var(--serif2);
  font-style: italic; font-weight: 300;
  font-size: clamp(1.1rem, 3vw, 1.6rem);
  color: var(--white2);
  margin-bottom: 28px;
  letter-spacing: .02em;
}
.hero-desc {
  font-family: var(--serif2);
  font-size: clamp(.9rem, 2vw, 1.1rem);
  color: var(--white2); line-height: 1.75;
  margin-bottom: 6px;
  max-width: 520px;
}
.hero-desc .gold-days {
  color: var(--gold); font-weight: 600;
}
.hero-btns {
  display: flex; flex-direction: column;
  gap: 12px; margin-top: 32px;
  align-items: flex-start;
}
.hero-btns .btn-gold { font-size: .75rem; padding: 16px 28px; }
.hero-btns .btn-ghost { font-size: .72rem; padding: 14px 28px; }

/* Trust row debajo de botones */
.hero-trust {
  display: flex; flex-wrap: wrap; gap: 16px;
  margin-top: 32px; padding-top: 24px;
  border-top: 1px solid var(--gold-border);
}
.trust-pill {
  display: flex; align-items: center; gap: 6px;
  font-family: var(--sans); font-size: .62rem; font-weight: 600;
  letter-spacing: .08em; text-transform: uppercase;
  color: var(--white3);
}
.trust-dot {
  width: 5px; height: 5px; border-radius: 50%;
  background: var(--gold); flex-shrink: 0;
  animation: blink 2.5s ease infinite;
}
@keyframes blink { 0%,100%{opacity:1}50%{opacity:.3} }

/* =====================================================
   TICKER
   ===================================================== */
.ticker {
  background: var(--black2);
  border-top: 1px solid var(--gold-border);
  border-bottom: 1px solid var(--gold-border);
  padding: 14px 0; overflow: hidden;
  mask-image: linear-gradient(90deg, transparent 0%, black 8%, black 92%, transparent 100%);
}
.ticker-track {
  display: flex; width: max-content;
  animation: ticker 30s linear infinite;
}
.ticker-track:hover { animation-play-state: paused; }
@keyframes ticker {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
.tick-item {
  display: flex; align-items: center; gap: 10px;
  padding: 0 28px; white-space: nowrap;
  font-family: var(--sans); font-size: .68rem; font-weight: 600;
  letter-spacing: .1em; text-transform: uppercase; color: var(--white3);
}
.tick-item::after { content: '◆'; color: var(--gold); font-size: .4rem; }

/* =====================================================
   STATS
   ===================================================== */
.stats-section {
  background: var(--black2);
  border-bottom: 1px solid var(--gold-border);
  padding: 56px 28px;
}
.stats-grid {
  display: grid; grid-template-columns: repeat(4,1fr);
  max-width: 960px; margin: 0 auto;
  border: 1px solid var(--gold-border);
  background: var(--gold-border); gap: 1px;
}
.stat {
  background: var(--black2);
  padding: 32px 20px; text-align: center;
  transition: background .25s;
}
.stat:hover { background: var(--black3); }
.stat-num {
  font-family: var(--serif); font-weight: 900;
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  color: var(--gold); line-height: 1; margin-bottom: 8px;
}
.stat-lbl {
  font-family: var(--sans); font-size: .62rem; font-weight: 600;
  letter-spacing: .1em; text-transform: uppercase; color: var(--white3);
}

/* =====================================================
   SECTION HELPERS
   ===================================================== */
section { padding: 96px 28px; }
.wrap { max-width: 1080px; margin: 0 auto; }

.s-eyebrow {
  display: flex; align-items: center; gap: 12px;
  font-family: var(--sans); font-size: .65rem; font-weight: 600;
  letter-spacing: .15em; text-transform: uppercase; color: var(--gold);
  margin-bottom: 20px;
}
.s-eyebrow::before { content: '——'; letter-spacing: -.1em; }

.s-title {
  font-family: var(--serif);
  font-size: clamp(2rem, 5.5vw, 3.8rem);
  font-weight: 900; line-height: 1.08;
  margin-bottom: 20px;
}
.s-title em { font-style: italic; color: var(--gold); }
.s-desc {
  font-family: var(--serif2); font-size: 1.05rem;
  color: var(--white2); max-width: 500px; line-height: 1.75;
}

/* =====================================================
   WHY
   ===================================================== */
.why-grid {
  display: grid; grid-template-columns: repeat(3,1fr);
  gap: 1px; margin-top: 56px;
  border: 1px solid var(--gold-border); background: var(--gold-border);
}
.why-card {
  background: var(--black2); padding: 32px 26px;
  transition: background .25s; position: relative; overflow: hidden;
}
.why-card::after {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, var(--gold), transparent);
  transform: scaleX(0); transform-origin: left;
  transition: transform .4s var(--ease);
}
.why-card:hover::after { transform: scaleX(1); }
.why-card:hover { background: var(--black3); }
.why-icon { display: block; margin-bottom: 16px; width: 52px; height: 52px; position: relative; }
.why-icon .ic { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; position: relative; }

/* --- WHY 3D icons --- */
.ic-bolt {
  width: 28px; height: 40px;
  background: linear-gradient(160deg, var(--gold2) 40%, var(--gold) 100%);
  clip-path: polygon(60% 0%,20% 50%,55% 50%,40% 100%,80% 45%,48% 45%);
  animation: bolt-pulse 1.6s ease-in-out infinite;
  filter: drop-shadow(0 0 6px rgba(201,168,76,.7));
}
@keyframes bolt-pulse {
  0%,100%{ transform: scale(1) rotateY(0deg); filter: drop-shadow(0 0 4px rgba(201,168,76,.5)); }
  50%    { transform: scale(1.15) rotateY(180deg); filter: drop-shadow(0 0 14px rgba(232,201,106,.9)); }
}
.ic-hospital {
  width: 36px; height: 36px;
  background: rgba(201,168,76,.1); border: 1.5px solid var(--gold);
  transform-style: preserve-3d;
  animation: hosp-spin 5s linear infinite;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.4rem; color: var(--gold); font-weight: 900;
  box-shadow: 0 0 10px rgba(201,168,76,.2);
}
@keyframes hosp-spin { from{transform:rotateY(0deg) rotateX(10deg)} to{transform:rotateY(360deg) rotateX(10deg)} }
.ic-brain {
  width: 38px; height: 34px;
  background: radial-gradient(circle at 40% 35%, rgba(201,168,76,.7) 0%, rgba(140,90,20,.5) 60%, transparent 100%);
  border-radius: 50% 45% 55% 40% / 40% 55% 45% 50%;
  animation: brain-morph 3s ease-in-out infinite;
  box-shadow: 0 0 14px rgba(201,168,76,.4);
}
@keyframes brain-morph {
  0%,100%{ border-radius:50% 45% 55% 40%/40% 55% 45% 50%; transform:scale(1) rotate(-5deg); }
  33%    { border-radius:40% 55% 45% 50%/55% 40% 50% 45%; transform:scale(1.08) rotate(0deg); }
  66%    { border-radius:55% 40% 50% 45%/45% 50% 40% 55%; transform:scale(1.04) rotate(5deg); }
}
.ic-globe {
  width: 38px; height: 38px; border-radius: 50%;
  border: 1.5px solid var(--gold);
  background: radial-gradient(circle at 35% 35%, rgba(201,168,76,.2) 0%, rgba(0,80,120,.3) 60%, rgba(0,40,80,.5) 100%);
  animation: globe-rot 4s linear infinite;
  position: relative;
  box-shadow: inset -4px -4px 10px rgba(0,0,0,.5), 0 0 10px rgba(201,168,76,.2);
}
.ic-globe::before {
  content: ''; position: absolute; inset: -6px; border-radius: 50%;
  border: 1px solid rgba(201,168,76,.3);
  animation: orbit-ring 2s linear infinite;
}
@keyframes globe-rot  { from{transform:rotateY(0deg)} to{transform:rotateY(360deg)} }
@keyframes orbit-ring { from{transform:rotateX(70deg) rotateZ(0deg)} to{transform:rotateX(70deg) rotateZ(360deg)} }
.ic-shield {
  width: 30px; height: 36px;
  background: linear-gradient(160deg, rgba(201,168,76,.5) 0%, rgba(140,90,20,.4) 100%);
  clip-path: polygon(50% 0%,100% 20%,100% 60%,50% 100%,0% 60%,0% 20%);
  animation: shield-flip 4s ease-in-out infinite;
  box-shadow: 0 0 12px rgba(201,168,76,.3);
}
@keyframes shield-flip {
  0%,100%{ transform:rotateY(0deg) scale(1); filter:brightness(1); }
  50%    { transform:rotateY(180deg) scale(1.1); filter:brightness(1.4) drop-shadow(0 0 8px var(--gold)); }
}
.ic-diamond {
  width: 34px; height: 34px;
  background: linear-gradient(135deg, rgba(201,168,76,.8) 0%, rgba(232,201,106,.5) 50%, rgba(201,168,76,.3) 100%);
  clip-path: polygon(50% 0%,100% 40%,75% 100%,25% 100%,0% 40%);
  animation: diamond-float 3s ease-in-out infinite;
  box-shadow: 0 0 16px rgba(201,168,76,.5), inset 0 0 8px rgba(255,255,255,.2);
}
@keyframes diamond-float {
  0%,100%{ transform:translateY(0) rotate(0deg) scale(1); filter:brightness(1); }
  33%    { transform:translateY(-6px) rotate(5deg) scale(1.1); filter:brightness(1.5) drop-shadow(0 0 10px var(--gold)); }
  66%    { transform:translateY(-3px) rotate(-3deg) scale(1.05); }
}

/* --- BLOG THUMB 3D --- */
.blog-thumb {
  height: 130px; display: flex; align-items: center; justify-content: center;
  border-bottom: 1px solid var(--gold-border);
  background: var(--black2);
  position: relative; overflow: hidden;
}
.bt-health {
  width: 60px; height: 60px;
  border-radius: 10px;
  background: rgba(201,168,76,.1);
  border: 1.5px solid var(--gold-border);
  animation: bt-health-spin 6s linear infinite;
  display: flex; align-items: center; justify-content: center;
  position: relative; z-index: 1; color: var(--gold);
  font-family: var(--sans); font-size: 1.8rem; font-weight: 900;
  box-shadow: 0 0 20px rgba(201,168,76,.15);
}
@keyframes bt-health-spin { from{transform:rotateY(0deg) rotateX(15deg)} to{transform:rotateY(360deg) rotateX(15deg)} }
.wheat-wrap {
  display: flex; align-items: flex-end; gap: 4px;
  height: 70px; position: relative; z-index: 1;
}
.wheat-stalk {
  width: 3px; border-radius: 2px;
  background: linear-gradient(to top, rgba(201,168,76,.9), rgba(201,168,76,.3));
  transform-origin: bottom center; position: relative;
}
.wheat-stalk::before {
  content: ''; position: absolute; top: -16px; left: 50%; transform: translateX(-50%);
  width: 10px; height: 18px;
  background: linear-gradient(to top, var(--gold), var(--gold2));
  border-radius: 50% 50% 40% 40%;
}
.ws-1 { height: 46px; animation: wheat-sway 2.2s ease-in-out infinite 0s; }
.ws-2 { height: 58px; animation: wheat-sway 2.2s ease-in-out infinite .2s; }
.ws-3 { height: 52px; animation: wheat-sway 2.2s ease-in-out infinite .4s; }
.ws-4 { height: 42px; animation: wheat-sway 2.2s ease-in-out infinite .1s; }
.ws-5 { height: 56px; animation: wheat-sway 2.2s ease-in-out infinite .35s; }
@keyframes wheat-sway {
  0%,100%{ transform:rotate(-10deg); filter:drop-shadow(2px 0 4px rgba(201,168,76,.3)); }
  50%    { transform:rotate(10deg);  filter:drop-shadow(-2px 0 8px rgba(201,168,76,.6)); }
}
.bt-rocket {
  font-size: 3rem; position: relative; z-index: 1;
  animation: rocket-3d 3s ease-in-out infinite;
  display: block;
}
@keyframes rocket-3d {
  0%,100%{ transform:translateY(6px) rotate(-5deg) scale(1); filter:drop-shadow(0 0 6px rgba(201,168,76,.4)); }
  50%    { transform:translateY(-12px) rotate(5deg) scale(1.1); filter:drop-shadow(0 0 16px rgba(232,201,106,.9)); }
}
  font-family: var(--sans); font-size: .6rem; font-weight: 600;
  letter-spacing: .12em; color: var(--gold); opacity: .6; margin-bottom: 10px;
}
.why-card h3 {
  font-family: var(--serif); font-weight: 700; font-size: 1.1rem;
  margin-bottom: 10px; line-height: 1.3;
}
.why-card p { font-family: var(--serif2); font-size: .9rem; color: var(--white2); line-height: 1.6; }

/* =====================================================
   SERVICES — lista original con imágenes 3D CSS
   ===================================================== */
.svc-section { background: var(--black2); }
.svc-list {
  display: flex; flex-direction: column; gap: 1px;
  margin-top: 52px;
  border: 1px solid var(--gold-border); background: var(--gold-border);
}
.svc-row {
  display: grid;
  grid-template-columns: 48px 120px 1fr auto 40px;
  align-items: center; gap: 20px;
  padding: 20px 24px;
  background: var(--black2);
  transition: all .25s var(--ease); cursor: pointer;
}
.svc-row:hover { background: var(--black3); }
.svc-num {
  font-family: var(--sans); font-size: .62rem; font-weight: 600;
  color: var(--white3); letter-spacing: .06em;
}
/* =====================================================
   SERVICE 3D OBJECTS — perspective containers
   ===================================================== */
.svc-obj {
  width: 90px; height: 90px;
  border: 1px solid var(--gold-border);
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, rgba(201,168,76,.05), rgba(0,0,0,0));
  transition: border-color .3s, background .3s;
  flex-shrink: 0; overflow: visible; position: relative;
  perspective: 240px;
  transform-style: preserve-3d;
}
.svc-row:hover .svc-obj { border-color: var(--gold); background: rgba(201,168,76,.08); }

/* ---- 01 NEURAL CUBE — rotating cube with glowing edges ---- */
.obj-neural {
  width: 46px; height: 46px;
  transform-style: preserve-3d;
  animation: cube-spin 6s linear infinite;
}
@keyframes cube-spin {
  from { transform: rotateX(20deg) rotateY(0deg); }
  to   { transform: rotateX(20deg) rotateY(360deg); }
}
.cube-face {
  position: absolute; width: 46px; height: 46px;
  border: 1.5px solid var(--gold);
  background: rgba(201,168,76,.06);
  display: flex; align-items: center; justify-content: center;
}
.cube-face.front  { transform: translateZ(23px); }
.cube-face.back   { transform: rotateY(180deg) translateZ(23px); }
.cube-face.left   { transform: rotateY(-90deg) translateZ(23px); }
.cube-face.right  { transform: rotateY(90deg) translateZ(23px); }
.cube-face.top    { transform: rotateX(90deg) translateZ(23px); }
.cube-face.bottom { transform: rotateX(-90deg) translateZ(23px); }
.cube-face.front::after, .cube-face.back::after {
  content: '';
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--gold);
  box-shadow: 0 0 8px var(--gold);
  animation: node-glow 1.8s ease-in-out infinite;
}
.cube-face.back::after { animation-delay: .9s; }
@keyframes node-glow { 0%,100%{opacity:.4;transform:scale(.8)} 50%{opacity:1;transform:scale(1.2)} }

/* ---- 02 DATA TORUS — donut spinning ---- */
.obj-torus3d {
  width: 50px; height: 50px;
  border-radius: 50%;
  border: 10px solid transparent;
  border-top-color: var(--gold);
  border-right-color: rgba(201,168,76,.5);
  border-bottom-color: rgba(201,168,76,.2);
  border-left-color: rgba(201,168,76,.7);
  box-shadow: 0 0 14px rgba(201,168,76,.3), inset 0 0 8px rgba(201,168,76,.1);
  animation: torus3d 3s linear infinite;
  transform-style: preserve-3d;
}
@keyframes torus3d {
  from { transform: rotateX(60deg) rotateZ(0deg); }
  to   { transform: rotateX(60deg) rotateZ(360deg); }
}

/* ---- 03 ROCKET PYRAMID — triangular prism floating ---- */
.obj-pyramid {
  width: 44px; height: 44px;
  transform-style: preserve-3d;
  animation: pyramid-float 4s ease-in-out infinite;
  position: relative;
}
@keyframes pyramid-float {
  0%,100% { transform: rotateY(0deg) rotateX(15deg) translateY(0); }
  25%     { transform: rotateY(90deg) rotateX(20deg) translateY(-5px); }
  50%     { transform: rotateY(180deg) rotateX(15deg) translateY(0); }
  75%     { transform: rotateY(270deg) rotateX(20deg) translateY(-5px); }
}
.pyr-face {
  position: absolute; width: 0; height: 0;
  border-left: 22px solid transparent;
  border-right: 22px solid transparent;
}
.pyr-face-1 { border-bottom: 38px solid rgba(201,168,76,.7); top:0; transform: translateZ(8px); }
.pyr-face-2 { border-bottom: 38px solid rgba(201,168,76,.4); top:0; transform: rotateY(120deg) translateZ(8px); }
.pyr-face-3 { border-bottom: 38px solid rgba(201,168,76,.55); top:0; transform: rotateY(240deg) translateZ(8px); }
.pyr-glow {
  position: absolute; bottom: 2px; left: 50%; transform: translateX(-50%);
  width: 30px; height: 6px;
  background: radial-gradient(ellipse, rgba(201,168,76,.6) 0%, transparent 70%);
  animation: pyr-glow-pulse 1.5s ease-in-out infinite;
}
@keyframes pyr-glow-pulse { 0%,100%{opacity:.4;transform:translateX(-50%) scaleX(.7)} 50%{opacity:1;transform:translateX(-50%) scaleX(1.2)} }

/* ---- 04 GEAR SPHERE — sphere with latitude rings ---- */
.obj-sphere3d {
  width: 50px; height: 50px;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%,
    rgba(201,168,76,.35) 0%,
    rgba(140,100,30,.25) 45%,
    rgba(8,8,16,.8) 100%);
  box-shadow: 0 0 20px rgba(201,168,76,.2), inset -6px -6px 14px rgba(0,0,0,.6), inset 4px 4px 10px rgba(201,168,76,.15);
  animation: sphere3d-spin 5s linear infinite;
  position: relative; overflow: hidden;
}
@keyframes sphere3d-spin {
  from { transform: rotateY(0deg); }
  to   { transform: rotateY(360deg); }
}
.obj-sphere3d::before {
  content: '';
  position: absolute; inset: -4px;
  border-radius: 50%;
  border: 1px solid rgba(201,168,76,.3);
  animation: sphere-ring1 3s linear infinite;
}
.obj-sphere3d::after {
  content: '';
  position: absolute; inset: 8px; top: -4px; bottom: -4px;
  border-radius: 50%;
  border: 1px solid rgba(201,168,76,.2);
  transform: rotateX(70deg);
}
@keyframes sphere-ring1 { from{transform:rotateX(70deg) rotateZ(0deg)} to{transform:rotateX(70deg) rotateZ(360deg)} }

/* ---- 05 GLOBE ICOSAHEDRON — wireframe globe ---- */
.obj-globe3d {
  width: 52px; height: 52px;
  border-radius: 50%;
  border: 1.5px solid rgba(201,168,76,.5);
  background: radial-gradient(circle at 38% 35%, rgba(201,168,76,.08) 0%, transparent 70%);
  transform-style: preserve-3d;
  animation: globe3d 7s linear infinite;
  position: relative;
}
@keyframes globe3d {
  from { transform: rotateY(0deg) rotateX(10deg); }
  to   { transform: rotateY(360deg) rotateX(10deg); }
}
.globe-ring {
  position: absolute; border-radius: 50%;
  border: 1px solid rgba(201,168,76,.35);
}
.globe-ring-1 { inset: 6px; transform: rotateX(70deg); }
.globe-ring-2 { inset: 6px; transform: rotateY(70deg); }
.globe-ring-3 { top: 25%; left: 0; right: 0; height: 1px; background: rgba(201,168,76,.3); border-radius: 0; border: none; }
.globe-ring-4 { top: 50%; left: 0; right: 0; height: 1px; background: rgba(201,168,76,.35); border-radius: 0; border: none; }
.globe-ring-5 { top: 75%; left: 0; right: 0; height: 1px; background: rgba(201,168,76,.3); border-radius: 0; border: none; }
.globe-dot {
  position: absolute; width: 5px; height: 5px; border-radius: 50%;
  background: var(--gold); box-shadow: 0 0 6px var(--gold);
  animation: globe-dot-orbit 7s linear infinite;
}
.globe-dot-1 { top: 50%; left: -2px; transform-origin: 28px 0; }
.globe-dot-2 { top: -2px; left: 50%; transform-origin: 0 28px; animation-delay: -3.5s; }
@keyframes globe-dot-orbit { from{transform:rotate(0deg) translateX(26px)} to{transform:rotate(360deg) translateX(26px)} }

/* ---- 06 CHAT HEXAGONAL PRISM ---- */
.obj-hex {
  width: 48px; height: 48px;
  transform-style: preserve-3d;
  animation: hex-spin 5s ease-in-out infinite;
}
@keyframes hex-spin {
  0%,100% { transform: rotateX(25deg) rotateY(0deg); }
  50%     { transform: rotateX(25deg) rotateY(180deg); }
}
.hex-face {
  position: absolute; width: 48px; height: 48px;
  clip-path: polygon(50% 0%,93% 25%,93% 75%,50% 100%,7% 75%,7% 25%);
  display: flex; align-items: center; justify-content: center;
  font-size: .9rem;
}
.hex-face.hf { background: rgba(201,168,76,.15); border: 1px solid rgba(201,168,76,.4); transform: translateZ(12px); }
.hex-face.hb { background: rgba(201,168,76,.08); transform: rotateY(180deg) translateZ(12px); }
.hex-face.hs1 { background: rgba(201,168,76,.12); transform: rotateY(60deg) translateZ(12px); }
.hex-face.hs2 { background: rgba(201,168,76,.10); transform: rotateY(-60deg) translateZ(12px); }
.hex-face.hs3 { background: rgba(201,168,76,.14); transform: rotateY(120deg) translateZ(12px); }
.hex-face.hs4 { background: rgba(201,168,76,.09); transform: rotateY(-120deg) translateZ(12px); }
.hex-glow {
  position: absolute; inset: -2px;
  clip-path: polygon(50% 0%,93% 25%,93% 75%,50% 100%,7% 75%,7% 25%);
  border: 1.5px solid var(--gold);
  animation: hex-glow-pulse 2s ease-in-out infinite;
  transform: translateZ(13px);
}
@keyframes hex-glow-pulse { 0%,100%{opacity:.3} 50%{opacity:.9;filter:drop-shadow(0 0 4px var(--gold))} }
.svc-info h3 {
  font-family: var(--serif); font-weight: 700; font-size: 1.2rem;
  margin-bottom: 2px;
}
.svc-info span {
  font-family: var(--sans); font-size: .62rem; font-weight: 600;
  letter-spacing: .1em; text-transform: uppercase; color: var(--gold);
}
.svc-tag {
  border: 1px solid var(--gold-border);
  color: var(--white3);
  font-family: var(--sans); font-size: .6rem; font-weight: 600;
  letter-spacing: .1em; text-transform: uppercase;
  padding: 4px 10px; white-space: nowrap;
}
.svc-arrow {
  color: var(--white3); font-size: 1rem;
  transition: all .25s; flex-shrink: 0;
}
.svc-row:hover .svc-arrow { color: var(--gold); transform: translateX(5px); }

/* =====================================================
   PRICING
   ===================================================== */
.pricing-grid {
  display: grid; grid-template-columns: repeat(3,1fr);
  gap: 1px; margin-top: 52px;
  border: 1px solid var(--gold-border); background: var(--gold-border);
}
.p-card {
  background: var(--black2); padding: 36px 28px;
  transition: background .25s; position: relative;
}
.p-card:hover { background: var(--black3); }
.p-card.feat {
  background: var(--black3);
  position: relative;
}
.p-card.feat::before {
  content: 'MÁS POPULAR';
  position: absolute; top: 0; left: 0; right: 0;
  background: var(--gold); color: var(--black);
  font-family: var(--sans); font-size: .6rem; font-weight: 700;
  letter-spacing: .15em; text-align: center; padding: 6px 0;
}
.p-card.feat { padding-top: 50px; }
.p-tier {
  font-family: var(--sans); font-size: .65rem; font-weight: 600;
  letter-spacing: .12em; text-transform: uppercase; color: var(--gold);
  margin-bottom: 8px;
}
.p-name { font-family: var(--serif); font-size: 1.4rem; font-weight: 900; margin-bottom: 8px; }
.p-desc { font-family: var(--serif2); font-size: .88rem; color: var(--white2); margin-bottom: 20px; line-height: 1.55; }
.p-price { display: flex; align-items: flex-end; gap: 3px; margin-bottom: 4px; }
.p-from { font-family: var(--sans); font-size: .62rem; color: var(--white3); margin-bottom: 4px; }
.p-sym  { font-family: var(--serif2); font-size: 1rem; color: var(--white2); margin-bottom: 4px; }
.p-amt  { font-family: var(--serif); font-size: 2.4rem; font-weight: 900; line-height: 1; color: var(--white); }
.p-cur  { font-family: var(--sans); font-size: .72rem; color: var(--white2); margin-bottom: 6px; font-weight: 600; }
.p-note { font-family: var(--sans); font-size: .6rem; color: var(--white3); margin-bottom: 22px; letter-spacing: .06em; }
.p-div  { height: 1px; background: var(--gold-border); margin-bottom: 20px; }
.p-feats { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px; }
.p-feats li {
  display: flex; align-items: flex-start; gap: 8px;
  font-family: var(--serif2); font-size: .88rem; color: var(--white2);
}
.p-feats li::before { content: '✦'; color: var(--gold); font-size: .6rem; flex-shrink: 0; margin-top: 5px; }
.btn-plan-ghost {
  display: flex; align-items: center; justify-content: center; gap: 7px;
  width: 100%; padding: 13px; border: 1px solid var(--gold-border);
  color: var(--gold); font-family: var(--sans); font-size: .68rem;
  font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
  transition: all .25s; cursor: pointer; background: transparent;
}
.btn-plan-ghost:hover { background: var(--gold-dim); border-color: var(--gold); }
.btn-plan-solid {
  display: flex; align-items: center; justify-content: center; gap: 7px;
  width: 100%; padding: 13px; background: var(--gold);
  color: var(--black); font-family: var(--sans); font-size: .68rem;
  font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
  transition: all .25s; cursor: pointer; border: 1px solid var(--gold);
}
.btn-plan-solid:hover { background: var(--gold2); box-shadow: 0 6px 24px var(--gold-glow); }

/* =====================================================
   CTA BAND
   ===================================================== */
.cta-band {
  text-align: center; padding: 96px 28px;
  background: linear-gradient(180deg, var(--black2) 0%, var(--black) 100%);
  border-top: 1px solid var(--gold-border); border-bottom: 1px solid var(--gold-border);
  position: relative; overflow: hidden;
}
.cta-band::before {
  content: ''; position: absolute; top: -60px; left: 50%; transform: translateX(-50%);
  width: 500px; height: 200px;
  background: radial-gradient(ellipse, rgba(201,168,76,.07) 0%, transparent 70%);
  pointer-events: none;
}
.cta-band .s-title { margin-bottom: 14px; }
.cta-band p { font-family: var(--serif2); font-size: 1.05rem; color: var(--white2); max-width: 460px; margin: 0 auto 32px; line-height: 1.7; }
.cta-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
.cta-proofs {
  display: flex; align-items: center; justify-content: center;
  gap: 24px; margin-top: 28px; flex-wrap: wrap;
}
.cta-proof {
  font-family: var(--sans); font-size: .6rem; font-weight: 600;
  letter-spacing: .1em; text-transform: uppercase; color: var(--white3);
  display: flex; align-items: center; gap: 5px;
}

/* =====================================================
   DIAGNOSIS / CONTACT
   ===================================================== */
.diag-section { background: var(--black2); }
.diag-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; margin-top: 56px; align-items: start; }
.diag-benefits { display: flex; flex-direction: column; gap: 22px; }
.ben { display: flex; gap: 16px; align-items: flex-start; }
.ben-icon {
  width: 44px; height: 44px; flex-shrink: 0;
  border: 1px solid var(--gold-border);
  display: flex; align-items: center; justify-content: center; font-size: 1rem;
  background: var(--gold-dim);
}
.ben-text h4 { font-family: var(--serif); font-weight: 700; font-size: 1rem; margin-bottom: 4px; }
.ben-text p { font-family: var(--serif2); font-size: .85rem; color: var(--white2); line-height: 1.6; }
.diag-cta { margin-top: 18px; display: flex; gap: 12px; flex-wrap: wrap; }

/* Form */
.form-card {
  background: var(--black3);
  border: 1px solid var(--gold-border); padding: 34px 28px;
}
.form-card h3 { font-family: var(--serif); font-size: 1.3rem; font-weight: 900; margin-bottom: 6px; }
.form-card > p { font-family: var(--serif2); font-size: .88rem; color: var(--white2); margin-bottom: 12px; }
.form-ssl {
  display: flex; align-items: center; gap: 8px;
  font-family: var(--sans); font-size: .62rem; font-weight: 600;
  letter-spacing: .06em; color: var(--white3); margin-bottom: 20px;
}
.fg { margin-bottom: 14px; }
.fg label { display: block; font-family: var(--sans); font-size: .62rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--white3); margin-bottom: 6px; }
.fg input, .fg select, .fg textarea {
  width: 100%; background: var(--black2);
  border: 1px solid rgba(201,168,76,.18); padding: 11px 14px;
  color: var(--white); font-family: var(--serif2); font-size: .9rem;
  outline: none; transition: border-color .25s, box-shadow .25s;
  -webkit-appearance: none;
}
.fg input:focus, .fg select:focus, .fg textarea:focus {
  border-color: var(--gold);
  box-shadow: 0 0 0 3px rgba(201,168,76,.08);
}
.fg textarea { resize: vertical; min-height: 80px; }
.fg select option { background: var(--black2); }
.fg-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

/* =====================================================
   BLOG
   ===================================================== */
.blog-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; margin-top: 52px; border: 1px solid var(--gold-border); background: var(--gold-border); }
.blog-card { background: var(--black2); overflow: hidden; transition: background .25s; }
.blog-card:hover { background: var(--black3); }
.blog-thumb {
  height: 130px; display: flex; align-items: center; justify-content: center;
  font-size: 2.4rem; border-bottom: 1px solid var(--gold-border);
  background: linear-gradient(135deg, rgba(201,168,76,.04), rgba(0,0,0,0));
}
.blog-body { padding: 24px 20px; }
.blog-cat { font-family: var(--sans); font-size: .6rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--gold); display: block; margin-bottom: 10px; }
.blog-body h3 { font-family: var(--serif); font-weight: 700; font-size: .95rem; line-height: 1.35; margin-bottom: 8px; }
.blog-body p { font-family: var(--serif2); font-size: .82rem; color: var(--white2); line-height: 1.6; margin-bottom: 14px; }
.blog-meta { font-family: var(--sans); font-size: .58rem; color: var(--white3); display: flex; gap: 10px; letter-spacing: .06em; }
.blog-link { display: flex; align-items: center; gap: 5px; margin-top: 10px; font-family: var(--sans); font-size: .65rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--gold); transition: gap .2s; }
.blog-link:hover { gap: 9px; }

/* =====================================================
   MARKETS
   ===================================================== */
.markets-section { background: var(--black2); }
.markets-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1px; margin-top: 44px; border: 1px solid var(--gold-border); background: var(--gold-border); }
.mkt-card { background: var(--black2); padding: 28px 20px; text-align: center; transition: background .25s; }
.mkt-card:hover { background: var(--black3); }
.mkt-flag { font-size: 2rem; margin-bottom: 10px; display: block; }
.mkt-card h3 { font-family: var(--serif); font-weight: 700; font-size: .95rem; margin-bottom: 6px; }
.mkt-card p { font-family: var(--serif2); font-size: .8rem; color: var(--white2); line-height: 1.5; }

/* =====================================================
   ABOUT
   ===================================================== */
.about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; margin-top: 52px; }
.about-text p { font-family: var(--serif2); font-size: 1.05rem; color: var(--white2); line-height: 1.8; margin-bottom: 20px; }
.about-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 24px; }
.about-tag {
  border: 1px solid var(--gold-border); color: var(--white3);
  font-family: var(--sans); font-size: .6rem; font-weight: 600;
  letter-spacing: .1em; text-transform: uppercase; padding: 5px 12px;
}

/* =====================================================
   FOOTER
   ===================================================== */
footer {
  background: var(--black2);
  border-top: 1px solid var(--gold-border);
  padding: 60px 28px 28px;
}
.footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; max-width: 1080px; margin: 0 auto 44px; }
.foot-brand { }
.foot-logo { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
.foot-letter {
  width: 40px; height: 40px; border: 1px solid var(--gold-border);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--serif); font-size: 1.1rem; font-weight: 900; color: var(--gold);
}
.foot-text { font-family: var(--sans); font-size: .65rem; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; color: var(--white2); line-height: 1.4; }
.foot-brand p { font-family: var(--serif2); font-size: .85rem; color: var(--white2); line-height: 1.65; max-width: 250px; margin-bottom: 18px; }
.foot-social { display: flex; gap: 8px; }
.soc-btn {
  width: 34px; height: 34px;
  border: 1px solid var(--gold-border);
  display: flex; align-items: center; justify-content: center;
  font-size: .75rem; color: var(--white3); transition: all .2s;
}
.soc-btn:hover { border-color: var(--gold); color: var(--gold); }
.foot-col h4 { font-family: var(--sans); font-size: .62rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--white3); margin-bottom: 16px; }
.foot-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
.foot-col ul a { font-family: var(--serif2); font-size: .88rem; color: var(--white2); transition: color .2s; }
.foot-col ul a:hover { color: var(--gold); }
.foot-bottom { max-width: 1080px; margin: 0 auto; padding-top: 24px; border-top: 1px solid var(--gold-border); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
.foot-bottom p { font-family: var(--sans); font-size: .62rem; color: var(--white3); letter-spacing: .04em; }
.foot-badges { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }

/* =====================================================
   FLOATING BUTTONS
   ===================================================== */
.float-wrap { position: fixed; bottom: 24px; right: 24px; z-index: 90; display: flex; flex-direction: column; align-items: flex-end; gap: 10px; }
.float-wa {
  display: flex; align-items: center; gap: 8px;
  background: var(--green-wa); color: #fff;
  font-family: var(--sans); font-size: .72rem; font-weight: 700;
  letter-spacing: .08em; text-transform: uppercase;
  padding: 12px 18px;
  box-shadow: 0 4px 20px rgba(37,211,102,.35);
  transition: all .25s; animation: bob 3s ease-in-out infinite;
}
.float-wa:hover { animation: none; transform: translateY(-2px); box-shadow: 0 8px 28px rgba(37,211,102,.5); }
@keyframes bob { 0%,100%{transform:translateY(0)}50%{transform:translateY(-4px)} }
#top-btn {
  position: fixed; bottom: 80px; right: 24px; z-index: 90;
  width: 40px; height: 40px; border: 1px solid var(--gold-border);
  background: var(--black2); color: var(--gold);
  font-size: .9rem; display: flex; align-items: center; justify-content: center;
  opacity: 0; transform: translateY(8px); transition: all .3s; cursor: pointer;
}
#top-btn.show { opacity: 1; transform: translateY(0); }
#top-btn:hover { background: var(--gold-dim); }

/* =====================================================
   GSAP initial states
   ===================================================== */
.gsap-fade { opacity: 0; }

/* =====================================================
   RESPONSIVE MOBILE-FIRST
   ===================================================== */
@media (max-width: 960px) {
  .why-grid { grid-template-columns: 1fr 1fr; }
  .pricing-grid { grid-template-columns: 1fr; background: none; border: none; gap: 12px; }
  .p-card { border: 1px solid var(--gold-border); }
  .p-card.feat { border-color: var(--gold); }
  .blog-grid { grid-template-columns: 1fr; background: none; border: none; gap: 14px; }
  .blog-card { border: 1px solid var(--gold-border); }
  .markets-grid { grid-template-columns: repeat(2,1fr); }
  .stats-grid { grid-template-columns: repeat(2,1fr); }
  .footer-grid { grid-template-columns: 1fr 1fr; }
  .foot-brand { grid-column: 1 / -1; }
  .about-grid { grid-template-columns: 1fr; }
  .svc-row { grid-template-columns: 32px 72px 1fr auto 32px; }
  .svc-obj { width: 72px; height: 72px; }
  .svc-tag { display: none; }
}

@media (max-width: 768px) {
  nav { padding: 0 18px; height: 60px; }
  .nav-links, .nav-right .ssl-badge { display: none; }
  .ham { display: flex; }

  .hero { padding: 0 20px 48px; min-height: 100svh; justify-content: flex-end; }
  .hero-btns { width: 100%; }
  .hero-btns .btn-gold,
  .hero-btns .btn-ghost { width: 100%; justify-content: center; padding: 16px 20px; }
  .hero-circle { display: none; }
  .obj-torus { width: 160px; height: 160px; right: -20px; border-width: 22px; }
  .obj-sphere { width: 80px; height: 80px; }

  section { padding: 64px 20px; }
  .diag-grid { grid-template-columns: 1fr; gap: 32px; }
  .fg-row { grid-template-columns: 1fr; }
  .why-grid { grid-template-columns: 1fr; }
  .footer-grid { grid-template-columns: 1fr; gap: 28px; }
  .foot-bottom { flex-direction: column; text-align: center; }
  .cta-btns { flex-direction: column; align-items: stretch; }
  .cta-btns .btn-gold,
  .cta-btns .btn-ghost { justify-content: center; }
  .stats-grid { grid-template-columns: repeat(2,1fr); }
  /* Services mobile — objeto 3D visible y prominente */
  .svc-row {
    display: flex; flex-direction: row;
    align-items: center; gap: 14px;
    padding: 18px 16px;
    grid-template-columns: unset;
  }
  .svc-obj {
    display: flex !important;
    width: 68px !important; height: 68px !important;
    flex-shrink: 0;
  }
  .svc-num { min-width: 24px; }
  .svc-info { flex: 1; min-width: 0; }
  .svc-info h3 { font-size: 1rem; }
  .svc-tag { display: none; }
  .svc-arrow { font-size: 1.2rem; margin-left: auto; }
  /* Scale 3D objects to fit mobile */
  .obj-neural  { transform: scale(.85); }
  .obj-torus3d { width: 44px !important; height: 44px !important; }
  .obj-pyramid { transform: scale(.85); }
  .obj-sphere3d{ width: 44px !important; height: 44px !important; }
  .obj-globe3d { width: 46px !important; height: 46px !important; }
  .obj-hex     { transform: scale(.85); }
  .float-wa span.float-label { display: none; }
}

@media (max-width: 480px) {
  .hero-title { font-size: 3rem; }
  .markets-grid { grid-template-columns: 1fr 1fr; }
}

/* Notch safe area */
@supports (padding: max(0px)) {
  nav { padding-left: max(18px, env(safe-area-inset-left)); padding-right: max(18px, env(safe-area-inset-right)); }
  .float-wrap { right: max(24px, env(safe-area-inset-right)); bottom: max(24px, env(safe-area-inset-bottom)); }
}

/* Touch active states */
@media (hover: none) {
  .btn-gold:active { transform: scale(.97); }
  .btn-ghost:active { transform: scale(.97); }
}

/* =====================================================
   AI CHATBOT WIDGET
   ===================================================== */
#ai-bot-btn {
  position: fixed; bottom: 84px; left: 24px; z-index: 91;
  width: 56px; height: 56px; border-radius: 50%;
  background: linear-gradient(135deg, #c9a84c, #8a6830);
  border: 2px solid rgba(201,168,76,.5);
  box-shadow: 0 4px 20px rgba(201,168,76,.3);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: all .25s;
  animation: bot-bob 3s ease-in-out infinite;
}
#ai-bot-btn:hover { transform: scale(1.08); box-shadow: 0 8px 30px rgba(201,168,76,.5); animation: none; }
@keyframes bot-bob { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-5px)} }
#ai-bot-btn svg { width: 30px; height: 30px; }

.bot-pulse {
  position: absolute; top: 2px; right: 2px;
  width: 12px; height: 12px; border-radius: 50%;
  background: #25D366;
  border: 2px solid var(--black);
  animation: pulse-ring 2s ease-in-out infinite;
}
@keyframes pulse-ring {
  0%,100% { transform: scale(1); opacity: 1; }
  50%      { transform: scale(1.3); opacity: .7; }
}

#ai-chat {
  position: fixed; bottom: 154px; left: 24px; z-index: 91;
  width: min(340px, calc(100vw - 48px));
  background: var(--black2);
  border: 1px solid var(--gold-border);
  box-shadow: 0 20px 60px rgba(0,0,0,.7);
  display: none; flex-direction: column;
  overflow: hidden;
}
#ai-chat.open { display: flex; }

.chat-head {
  background: linear-gradient(135deg, #1a1408, #0d0d18);
  border-bottom: 1px solid var(--gold-border);
  padding: 14px 16px;
  display: flex; align-items: center; gap: 10px;
}
.chat-head-avatar {
  width: 36px; height: 36px; border-radius: 50%;
  background: linear-gradient(135deg, #c9a84c, #8a6830);
  display: flex; align-items: center; justify-content: center;
  font-size: .9rem; flex-shrink: 0;
}
.chat-head-info { flex: 1; }
.chat-head-info strong { font-family: var(--sans); font-size: .72rem; font-weight: 700; letter-spacing: .06em; display: block; color: var(--gold); }
.chat-head-info span { font-family: var(--sans); font-size: .6rem; color: var(--white3); display: flex; align-items: center; gap: 4px; }
.chat-head-info span::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: #25D366; display: block; }
.chat-close { color: var(--white3); font-size: 1rem; cursor: pointer; padding: 4px; transition: color .2s; line-height: 1; }
.chat-close:hover { color: var(--gold); }

.chat-msgs {
  padding: 16px; display: flex; flex-direction: column; gap: 10px;
  max-height: 240px; overflow-y: auto;
  scrollbar-width: thin; scrollbar-color: var(--gold-border) transparent;
}
.chat-msgs::-webkit-scrollbar { width: 4px; }
.chat-msgs::-webkit-scrollbar-thumb { background: var(--gold-border); border-radius: 2px; }

.msg {
  display: flex; gap: 8px; align-items: flex-end;
}
.msg-bot { justify-content: flex-start; }
.msg-user { justify-content: flex-end; }
.msg-bubble {
  padding: 9px 12px; max-width: 80%;
  font-family: var(--serif2); font-size: .85rem; line-height: 1.5;
}
.msg-bot .msg-bubble {
  background: var(--black3);
  border: 1px solid var(--gold-border);
  color: var(--white2);
  border-bottom-left-radius: 0;
}
.msg-user .msg-bubble {
  background: var(--gold);
  color: var(--black);
  font-weight: 600;
  border-bottom-right-radius: 0;
}
.msg-time { font-family: var(--sans); font-size: .55rem; color: var(--white3); margin-bottom: 2px; }

.chat-typing { display: flex; gap: 4px; align-items: center; padding: 4px 0; }
.typing-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--gold); opacity: .4;
  animation: type-bounce .9s ease-in-out infinite;
}
.typing-dot:nth-child(2) { animation-delay: .15s; }
.typing-dot:nth-child(3) { animation-delay: .3s; }
@keyframes type-bounce { 0%,80%,100%{transform:translateY(0);opacity:.4} 40%{transform:translateY(-5px);opacity:1} }

.chat-quick {
  display: flex; gap: 6px; flex-wrap: wrap; padding: 0 16px 10px;
}
.quick-btn {
  background: transparent;
  border: 1px solid var(--gold-border);
  color: var(--gold);
  font-family: var(--sans); font-size: .58rem; font-weight: 600;
  letter-spacing: .06em; padding: 5px 10px;
  cursor: pointer; transition: all .2s;
}
.quick-btn:hover { background: var(--gold-dim); border-color: var(--gold); }

.chat-input-row {
  display: flex; gap: 0;
  border-top: 1px solid var(--gold-border);
}
.chat-input {
  flex: 1; background: var(--black);
  border: none; outline: none;
  padding: 12px 14px;
  color: var(--white); font-family: var(--serif2); font-size: .85rem;
}
.chat-input::placeholder { color: var(--white3); }
.chat-send {
  background: var(--gold); color: var(--black);
  border: none; padding: 0 16px;
  font-family: var(--sans); font-size: .7rem; font-weight: 700;
  letter-spacing: .06em; cursor: pointer; transition: background .2s;
}
.chat-send:hover { background: var(--gold2); }

@supports (padding: max(0px)) {
  #ai-bot-btn { left: max(24px, env(safe-area-inset-left)); }
  #ai-chat    { left: max(24px, env(safe-area-inset-left)); }
}
@media (max-width: 480px) {
  #ai-chat { width: calc(100vw - 32px); left: 16px; bottom: 148px; }
  #ai-bot-btn { left: 16px; bottom: 78px; }
}
</style>
</head>
