<!-- ======================== JS ======================== -->
<script>
gsap.registerPlugin(ScrollTrigger);

/* Stars */
(function() {
  const c = document.getElementById('stars');
  for (let i = 0; i < 60; i++) {
    const s = document.createElement('div');
    s.className = 'star';
    const size = Math.random() * 3 + 1;
    s.style.cssText = `
      width:${size}px; height:${size}px;
      top:${Math.random()*100}%;
      left:${Math.random()*100}%;
      --dur:${2 + Math.random()*4}s;
      --del:${Math.random()*4}s;
    `;
    c.appendChild(s);
  }
})();

/* HERO entrance */
gsap.set('#hero-content', { opacity: 0, y: 40 });
gsap.to('#hero-content', { opacity: 1, y: 0, duration: 1.1, ease: 'power3.out', delay: 0.3 });

/* Orb/toro parallax */
gsap.to('.obj-torus', {
  y: -80, rotation: 15,
  scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 2 }
});
gsap.to('.obj-sphere', {
  y: -50,
  scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 2.5 }
});

/* Scroll reveal — todas las .gsap-fade */
document.querySelectorAll('.gsap-fade').forEach(el => {
  if (el.id === 'hero-content') return;
  gsap.fromTo(el,
    { opacity: 0, y: 30 },
    {
      opacity: 1, y: 0, duration: 0.75, ease: 'power2.out',
      scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' }
    }
  );
});

/* Counters */
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (!e.isIntersecting) return;
    const el = e.target, n = el.querySelector('[data-t]');
    if (!n || n.dataset.done) return;
    n.dataset.done = 1;
    const target = parseInt(n.dataset.t);
    const suf = n.dataset.s || '', pre = n.dataset.p || '';
    let count = 0;
    const step = Math.max(1, Math.ceil(target / 40));
    const t = setInterval(() => {
      count = Math.min(count + step, target);
      n.textContent = pre + count + suf;
      if (count >= target) clearInterval(t);
    }, 45);
  });
}, { threshold: 0.5 });
document.querySelectorAll('.stat').forEach(s => obs.observe(s));

/* Progress bar + top btn */
window.addEventListener('scroll', () => {
  const pct = window.scrollY / (document.body.scrollHeight - window.innerHeight) * 100;
  document.getElementById('prog').style.width = pct + '%';
  const tb = document.getElementById('top-btn');
  window.scrollY > 400 ? tb.classList.add('show') : tb.classList.remove('show');
}, { passive: true });

/* Hamburger */
const ham = document.getElementById('ham'), mob = document.getElementById('mob');
ham.addEventListener('click', () => {
  mob.classList.toggle('open');
  const [a,b,c] = ham.querySelectorAll('span');
  if (mob.classList.contains('open')) {
    a.style.transform = 'rotate(45deg) translate(5px,5px)';
    b.style.opacity = '0';
    c.style.transform = 'rotate(-45deg) translate(5px,-5px)';
  } else {
    [a,b,c].forEach(s => { s.style.transform=''; s.style.opacity=''; });
  }
});
document.querySelectorAll('.ml,.mob .btn-gold').forEach(l => {
  l.addEventListener('click', () => {
    mob.classList.remove('open');
    ham.querySelectorAll('span').forEach(s => { s.style.transform=''; s.style.opacity=''; });
  });
});

/* Smooth anchor */
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    const t = document.querySelector(a.getAttribute('href'));
    if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
  });
});

/* ===== AI CHATBOT ===== */
const botReplies = {
  'precio':    ['El plan Esencial parte desde <strong>$990 USD</strong>, el Profesional desde <strong>$2,500 USD</strong> y el Premium IA desde <strong>$5,000 USD</strong>. ¿Te interesa alguno en particular?'],
  'esencial':  ['El plan Esencial ($990 USD) incluye web con IA, SEO básico, correo corporativo, Google My Business, agente WhatsApp y 30 días de soporte. ¡Todo en 7 días! 🚀'],
  'profesional':['El plan Profesional ($2,500 USD) incluye todo lo del Esencial más identidad visual, SEO 3 meses, CRM y dashboard de métricas. 60 días de soporte incluido.'],
  'premium':   ['El Premium IA ($5,000 USD) es nuestro paquete completo: agente IA personalizado, automatización, pipeline de datos, formación y 90 días de soporte prioritario.'],
  'diagnóstico':['¡Genial! El diagnóstico es 100% gratuito y sin compromiso. Te identificamos 3 oportunidades de IA, estimamos el ROI y te damos un roadmap. ¿Te escribo por WhatsApp? 👇', 'whatsapp'],
  'servicio':  ['Ofrecemos 6 servicios: Agentes de IA, Consultoría Estratégica, Formación Corporativa, Desarrollo de Productos IA, MLOps & Datos y Presencia Digital. ¿Cuál te interesa?'],
  'humano':    ['¡Claro! Te conecto con el equipo ahora mismo por WhatsApp. ¡Responden en menos de 24h! 💬', 'whatsapp'],
  'días':      ['Sí, implementamos en <strong>7 días</strong> o menos. Es nuestra garantía. Si no cumplimos los KPIs pactados, el siguiente sprint es gratis. ✅'],
  'colombia':  ['Tenemos sede en Bucaramanga, Colombia, pero operamos en Latam, USA y Europa en 4 idiomas: español, inglés, portugués y alemán. 🌍'],
  default:     ['Gracias por tu mensaje. Para darte la mejor respuesta, ¿te gustaría hablar directamente con nuestro equipo por WhatsApp?', 'whatsapp']
};

function toggleChat() {
  const c = document.getElementById('ai-chat');
  c.classList.toggle('open');
  if (c.classList.contains('open')) {
    setTimeout(() => document.getElementById('chat-input').focus(), 300);
  }
}

function addMsg(text, type) {
  const msgs = document.getElementById('chat-msgs');
  const div = document.createElement('div');
  div.className = `msg msg-${type}`;
  const now = new Date().toLocaleTimeString('es',{hour:'2-digit',minute:'2-digit'});
  div.innerHTML = `<div><div class="msg-time">${now}</div><div class="msg-bubble">${text}</div></div>`;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
}

function showTyping() {
  const msgs = document.getElementById('chat-msgs');
  const div = document.createElement('div');
  div.className = 'msg msg-bot'; div.id = 'typing-ind';
  div.innerHTML = `<div><div class="msg-bubble chat-typing"><span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span></div></div>`;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
}

function removeTyping() {
  const t = document.getElementById('typing-ind');
  if (t) t.remove();
}

function addWaButton() {
  const msgs = document.getElementById('chat-msgs');
  const div = document.createElement('div');
  div.className = 'msg msg-bot';
  div.innerHTML = `<div><div class="msg-bubble" style="padding:0"><a href="https://wa.me/573025280632" target="_blank" style="display:flex;align-items:center;gap:8px;background:#25D366;color:#fff;padding:10px 14px;font-family:var(--sans);font-size:.7rem;font-weight:700;letter-spacing:.08em">💬 ABRIR WHATSAPP →</a></div></div>`;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
}

function getBotReply(text) {
  const t = text.toLowerCase();
  for (const [key, val] of Object.entries(botReplies)) {
    if (key !== 'default' && t.includes(key)) return val;
  }
  return botReplies.default;
}

function sendBotReply(userText) {
  showTyping();
  setTimeout(() => {
    removeTyping();
    const reply = getBotReply(userText);
    addMsg(reply[0], 'bot');
    if (reply[1] === 'whatsapp') setTimeout(() => addWaButton(), 400);
    document.getElementById('chat-quick').style.display = 'none';
  }, 1000 + Math.random() * 600);
}

function sendMsg() {
  const inp = document.getElementById('chat-input');
  const text = inp.value.trim();
  if (!text) return;
  addMsg(text, 'user');
  inp.value = '';
  sendBotReply(text);
}

function quickMsg(text) {
  addMsg(text, 'user');
  sendBotReply(text);
  document.getElementById('chat-quick').style.display = 'none';
}

/* Form submit */
function submitForm(btn) {
  btn.textContent = '✅ ¡RECIBIDO! TE CONTACTAMOS EN <24H';
  btn.style.background = '#0fba81';
  btn.disabled = true;
  setTimeout(() => {
    btn.textContent = '🚀 QUIERO MI DIAGNÓSTICO GRATIS';
    btn.style.background = '';
    btn.disabled = false;
  }, 5000);
}
</script>
</body>
</html>
